# =================================
# Ramzee Environment Configuration
# =================================
# Copy this file to .env and fill in your values

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug

# Database (PostgreSQL)
DATABASE_URL=postgresql://ramzee:ramzee_dev_password@localhost:5432/ramzee

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:19006

# Kafka
KAFKA_BROKERS=localhost:9092

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=ramzee
MINIO_SECRET_KEY=ramzee_minio_password
MINIO_BUCKET=ramzee-media
MINIO_USE_SSL=false

# Email (Mailhog in development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@ramzee.app

# URI OAuth (for .edu email verification)
# URI_OAUTH_CLIENT_ID=
# URI_OAUTH_CLIENT_SECRET=
# URI_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback/uri
